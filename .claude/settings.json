{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Glob(./**)",
      "Grep(./**)",
      "Edit(./app/**)",
      "Edit(./components/**)",
      "Edit(./lib/**)",
      "Edit(./public/**)",
      "Edit(./content/**)",
      "Edit(./*.md)",
      "Edit(./*.json)",
      "Edit(./*.ts)",
      "Edit(./*.mjs)",
      "Edit(./.claude/**)",
      "Write(./app/**)",
      "Write(./components/**)",
      "Write(./lib/**)",
      "Write(./content/**)",
      "Write(./.claude/**)",
      "Bash(yarn dev)",
      "Bash(yarn dev *)",
      "Bash(yarn build)",
      "Bash(yarn build *)",
      "Bash(yarn lint)",
      "Bash(yarn lint *)",
      "Bash(yarn add *)",
      "Bash(yarn remove *)",
      "Bash(yarn install)",
      "Bash(yarn upgrade *)",
      "Bash(npx tsc *)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx playwright *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(git stash *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git switch *)",
      "Bash(git checkout *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(node *)",
      "Bash(rg *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(yarn publish *)",
      "Bash(npm publish *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/secrets/**)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(rm -rf *)",
      "Edit(./next.config.ts)",
      "Edit(./tsconfig.json)",
      "Edit(./package.json)",
      "Edit(./tailwind.config.*)",
      "Edit(./.gitignore)"
    ]
  },
  "env": {
    "BROWSER": "none"
  }
}
